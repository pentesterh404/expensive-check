generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ExpenseStatus {
  CONFIRMED
  PENDING_REVIEW
  UNPARSED
  DELETED
}

model User {
  id              String             @id @default(cuid())
  email           String             @unique
  passwordHash    String
  displayName     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  telegramLinks   TelegramIdentity[]
  telegramMessages TelegramMessage[]
  categories      Category[]
  expenses        Expense[]
  auditLogs       AuditLog[]
  linkCodes       TelegramLinkCode[]
}

model TelegramIdentity {
  id             String   @id @default(cuid())
  userId         String
  telegramUserId BigInt   @unique
  telegramChatId BigInt?
  username       String?
  linkedAt       DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TelegramLinkCode {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TelegramMessage {
  id              String   @id @default(cuid())
  userId          String?
  chatId          BigInt
  messageId       Int
  telegramUserId  BigInt?
  rawUpdate       Json
  rawText         String?
  parsedPayload   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  expenses        Expense[]

  @@unique([chatId, messageId])
  @@index([userId])
}

model Category {
  id        String    @id @default(cuid())
  userId    String
  name      String
  slug      String
  color     String?
  icon      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses  Expense[]

  @@unique([userId, slug])
  @@index([userId])
}

model Expense {
  id                String       @id @default(cuid())
  userId            String
  telegramMessageId String?      @unique
  categoryId        String?
  expenseDate       DateTime
  amount            Decimal      @db.Decimal(14, 2)
  currency          String       @default("VND")
  rawText           String?
  description       String?
  tags              String[]
  wallet            String?
  parseConfidence   Float        @default(0)
  status            ExpenseStatus @default(PENDING_REVIEW)
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  telegramMessage   TelegramMessage? @relation(fields: [telegramMessageId], references: [id], onDelete: SetNull)

  @@index([userId, expenseDate])
  @@index([userId, status])
  @@index([telegramMessageId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  resourceId String?
  meta      Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}
